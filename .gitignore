# =============================================================================
# Git ignore for embedded Keil MDK-ARM projects (GD32H7 workspace)
# =============================================================================

# ---------------------------------------------------------------------------
# Build output directories (all projects)
# ---------------------------------------------------------------------------
**/output/
**/list/
**/RTE/

# ---------------------------------------------------------------------------
# Compiler / linker build artifacts (anywhere in workspace)
# ---------------------------------------------------------------------------
*.o
*.d
*.axf
*.hex
*.lnp
*.dep
*.map
*.crf
*.lst
*.sct

# ---------------------------------------------------------------------------
# Keil user-specific files (do NOT track — machine-dependent)
# ---------------------------------------------------------------------------
*.uvguix.*
*.uvoptx
*.scvd

# J-Link / ULINK settings (machine-dependent)
*.jlink
JLinkLog.txt
JLinkSettings.ini

# ---------------------------------------------------------------------------
# Editor / IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS generated files
# ---------------------------------------------------------------------------
Thumbs.db
Desktop.ini
.DS_Store

# ---------------------------------------------------------------------------
# Workspace miscellany — not source code
# ---------------------------------------------------------------------------
*.rar
test.txt
.claude/
AN111_GD32H7xx_ruanjiankaifazhinan_Rev1.0.pdf
AN212 GDemWin GD32H7xx系列移植指南_Rev1.1.pdf
